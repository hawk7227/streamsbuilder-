# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string
# Local:      postgres://streams:streams@localhost:5432/streams_dev
# Production: use your provider's connection string with ?sslmode=require
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used for: BullMQ queues, pub/sub run event streaming, worker heartbeat
# Local:      redis://localhost:6379
# Production: use your provider's URL with auth
REDIS_URL=

# ─── S3 / Object storage ──────────────────────────────────────────────────────
# Compatible with AWS S3, Supabase Storage (S3 API), Cloudflare R2
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required. Bot orchestration uses gpt-4o for builder/runtime/deploy modes.
OPENAI_API_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Guards /system-status and /api/system-status.
# Generate: openssl rand -hex 32
ADMIN_SECRET=

# ─── App URLs ─────────────────────────────────────────────────────────────────
# Public URL of the web app — used in emails, links, CORS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal URL of the API server (used by Next.js route handlers to proxy requests)
# In production: set to your Railway/Fly/Docker internal service URL
API_INTERNAL_URL=http://localhost:3001

# ─── CI (set automatically by GitHub Actions — do not set manually) ───────────
# CI=true
# GITHUB_SHA=
# GITHUB_REF_NAME=
# CI_LINT_PASSED=
# CI_TYPECHECK_PASSED=
# CI_TEST_PASSED=

# ─── Deploy (set as GitHub Actions secrets — never in this file) ──────────────
# VERCEL_TOKEN=

# ─── Supabase (required for AIAssistant floater system) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Providers (floater system) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# ─── Video generation providers ───────────────────────────────────────────────
KLING_API_KEY=
KLING_API_SECRET=
RUNWAY_API_KEY=
FAL_KEY=

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── streams-assistant agentic route ─────────────────────────────────────────
GITHUB_TOKEN=
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_EDITOR_PROJECT_ID=
DO_API_TOKEN=
DO_APP_ID=
