    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@streams/contracts": "workspace:*",
    "drizzle-orm": "^0.32.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.23.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
