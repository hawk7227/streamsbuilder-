{
  "name": "@streams/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/build-report.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@streams/ai": "workspace:*",
    "@streams/contracts": "workspace:*",
    "@streams/integrations": "workspace:*",
    "@streams/system-status": "workspace:*",
    "express": "^4.19.0",
    "@streams/db": "workspace:*",
    "@streams/core": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
